# ===========================================================
# VTMS 루트 .env 예시 (실제 .env 는 .gitignore 로 커밋 금지)
# 사용: 이 파일을 복사해 .env 로 만들고 값을 채운다.
#   cp .env.example .env
# 프론트엔드 빌드(scripts/build_web.sh)와 배포(redeploy.sh)가 이 값을 읽어
# --dart-define 으로 Flutter 앱에 주입한다.
# ===========================================================

# DB (참고용; 백엔드는 backend/.env 의 DATABASE_URL 사용)
KTMS_DB_HOST=
KTMS_DB_PORT=5432
KTMS_DB_NAME=
KTMS_DB_USER=
KTMS_DB_PASSWORD=
KTMS_DB_SCHEMA=vtms

# SFTP 배포 대상 서버
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_REMOTE_PATH=/web

# 백엔드 API 베이스 URL. 같은 도메인 정적 서빙이면 비워둠(상대경로 /api).
API_BASE_URL=

# Firebase 웹 설정 (Firebase 콘솔 > 프로젝트 설정 > 웹 앱)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=

# Firebase 안드로이드 앱 (선택)
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=

# 구글 OAuth 클라이언트 ID (google_sign_in 사용 시)
GOOGLE_WEB_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=

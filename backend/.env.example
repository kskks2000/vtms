# PostgreSQL 11 연결 정보 (비밀번호 특수문자는 URL 인코딩: ! -> %21)
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
# 테이블이 위치한 스키마
DB_SCHEMA=vtms

# JWT 설정 (운영 환경에서는 반드시 안전한 랜덤 값으로 교체)
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 로그인 보안 정책
MAX_FAILED_LOGIN=5
LOCK_MINUTES=15

# CORS 허용 출처 (Flutter 웹 개발 서버). 콤마로 구분
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# 구글 OAuth (Google Cloud Console 에서 발급한 클라이언트 ID, 콤마로 여러 개)
GOOGLE_CLIENT_IDS=
GOOGLE_AUTO_PROVISION=false

# 기본 테넌트 (시드/신규 유저 배정용)
DEFAULT_TENANT_CODE=DEFAULT
DEFAULT_TENANT_NAME=기본 테넌트

# 데모 관리자 시드 (개발용)
SEED_USER_EMAIL=admin@vtms.com
SEED_USER_PASSWORD=admin1234
SEED_USER_NAME=관리자

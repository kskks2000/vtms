# ===========================================================
# VTMS .gitignore (Flutter + FastAPI/Python + PostgreSQL)
# ===========================================================

# -----------------------------------------------------------
# 공통 / OS
# -----------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
*.bak
*.swp
*~

# -----------------------------------------------------------
# 환경 변수 / 시크릿
# -----------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
config/secrets*.yaml

# 네이버 지도 / 외부 API 키
naver_map_keys*
api_keys*

# -----------------------------------------------------------
# IDE / 에디터
# -----------------------------------------------------------
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# Claude Code 로컬 설정(머신 전용 권한 등) — 커밋 금지
.claude/settings.local.json

# ===========================================================
# 백엔드 (FastAPI / Python)
# ===========================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# 가상환경
.venv/
venv/
env/
ENV/

# 패키징 / 빌드
build/
dist/
*.egg-info/
.eggs/
*.egg

# 테스트 / 커버리지
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# 로컬 DB 파일 / 덤프
*.sqlite3
*.db
*.sql.bak
*.dump

# ===========================================================
# 프론트엔드 (Flutter / Dart)
# ===========================================================
# Flutter/Dart/Pub
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds

# 빌드 산출물
*.class
*.lock.orig

# 심볼 / 디버그
app.*.symbols
app.*.map.json

# -----------------------------------------------------------
# Flutter - Android
# -----------------------------------------------------------
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks
*.keystore

# -----------------------------------------------------------
# Flutter - iOS (참고용, 안드로이드 우선)
# -----------------------------------------------------------
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/Generated.xcconfig
**/ios/Pods/
**/ios/.symlinks/

# -----------------------------------------------------------
# Flutter - Web
# -----------------------------------------------------------
**/web/.dart_tool/

# ===========================================================
# 기타
# ===========================================================
node_modules/
coverage/
*.orig
